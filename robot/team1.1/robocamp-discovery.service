[Unit]
Description=Robocamp robot 158 Unity address discovery
After=network.target

[Service]
Type=simple
User=nobody
ExecStart=/usr/bin/python3 /usr/local/lib/robocamp_discovery.py
Restart=always
RestartSec=1
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true

[Install]
WantedBy=multi-user.target
